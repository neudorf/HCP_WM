Split the string by whitespace and convert to a list of integers\n","patient_numbers_list = [int(num) for num in numbers_string.split() if num.strip()]\n","# Convert the list to a NumPy array\n","patient_numbers_array = np.array(patient_numbers_list)\n","\n","if debug:\n","    print(\"NumPy array of patient numbers:\")\n","    display(patient_numbers_array)\n","    print(\"Shape of the array:\", patient_numbers_array.shape)\n","\n","# --------------------------------------------------\n","\n","def process_patient(patient_number):\n","    patient_number_string = str(patient_number)\n","\n","    out_LR = save_dir + patient_number_string + \"_LR.npy\"\n","    out_RL = save_dir + patient_number_string + \"_RL.npy\"\n","\n","    # Skip if BOTH outputs already exist\n","    if (not remake) and os.path.exists(out_LR) and os.path.exists(out_RL):\n","        if debug:\n","            print(f\"Skipping {patient_number}\")\n","        return\n","\n","    dtseries_file_LR = main_path + patient_number_string + dtseries_file_path_LR\n","    dtseries_file_RL = main_path + patient_number_string + dtseries_file_path_RL\n","\n","    # Load dtseries file, (timepoints, grayordinates), HCP Normlization\n","    data_norm_LR = hcp.normalize(nib.load(dtseries_file_LR).get_fdata())\n","    data_norm_RL = hcp.normalize(nib.load(dtseries_file_RL).get_fdata())\n","    data_norm_parcel_LR = hcp.parcellate(data_norm_LR, hcp.mmp)\n","    data_norm_parcel_RL = hcp.parcellate(data_norm_RL, hcp.mmp)\n","\n","    np.save(out_LR, data_norm_parcel_LR)\n","    np.save(out_RL, data_norm_parcel_RL)\n","\n","    if debug:\n","        print(f\"Processed {patient_number}\")\n","\n","# --------------------------------------------------\n","if parallel_work:\n","    Parallel(n_jobs=CPU_processes_count, backend=\"loky\")(\n","        delayed(process_patient)(p) for p in patient_numbers_array\n","    )\n","else:\n","    for p in patient_numbers_array:\n","        process_patient(p)"],"metadata":{"id":"uJzNU3bgNF